{
  "name": "mae-mfe-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone MAE/MFE (Maximum Adverse / Favorable Excursion) analysis dashboard — multi-asset trade-metrics lab with in-sample / out-of-sample comparison, EV risk matrix, and portfolio cycling.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --disable-warning=ExperimentalWarning server/index.mjs",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "jest --no-coverage"
  },
  "dependencies": {
    "lucide-react": "^0.556.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
